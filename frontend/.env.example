# ============================================
# CONFIGURAÇÃO DA API
# ============================================
# O sistema detecta automaticamente o IP baseado na plataforma:
# - Web: http://localhost:3333/api
# - Android Emulator: http://10.0.2.2:3333/api
# - iOS Simulator: http://localhost:3333/api
# - Dispositivos Físicos: Usa o IP do Expo automaticamente
#
# Descomente para usar uma URL customizada:
# EXPO_PUBLIC_API_URL=http://192.168.x.x:3333/api
